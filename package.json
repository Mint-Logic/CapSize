{
  "name": "capsize",
  "productName": "CapSize",
  "version": "1.0.0",
  "description": "A screen capturing and annotating tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js",
    "install": "node-gyp rebuild",
    "prebuild": "prebuildify --napi --strip",
    "test": "vitest"
  },
  "build": {
    "appId": "com.mintlogic.capsize",
    "productName": "CapSize",
    "directories": {
      "output": "dist"
    },
    "fileAssociations": [
      {
        "ext": "mint",
        "name": "Mint Logic Cryptographic Seal",
        "description": "Hardware License Shard for Mint Logic Pro",
        "icon": "assets/mint-icon.ico",
        "role": "Viewer"
      }
    ],
    "files": [
      "**/*",
      "!dist/*",
      "!build.js",
      "!cpp/*",
      "!binding.gyp"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": {
    "name": "Mint Logic"
  },
  "license": "MIT",
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.5.0",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "prebuildify": "^6.0.1",
    "vitest": "^4.1.3"
  }
}
