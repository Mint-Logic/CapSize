{
  "name": "capsize",
  "productName": "CapSize",
  "version": "1.0.0",
  "description": "A screen capturing and annotating tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:pro": "cross-env TEST_PRO_MODE=true electron .",
    "build": "node build.js core",
    "rebuild": "npm rebuild"
  },
  "author": "Mint Logic",
  "license": "MIT",
  "build": {
    "appId": "com.mintlogic.capsize",
    "productName": "CapSize",
    "directories": {
      "output": "dist/core"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/*",
      "!**/*.{ts,tsx}",
      "!build.js"
    ],
    "fileAssociations": [
  {
    "ext": "mint",
    "name": "Mint Logic Cryptographic Seal",
    "description": "Hardware License Shard for Mint Logic Pro",
    "icon": "assets/mint-icon.ico",
    "role": "Viewer"
  }
],
   "win": {
  "target": "nsis",
  "icon": "assets/icon.ico",
  "executableName": "CapSizeCore"
},
    "nsis": {
      "artifactName": "CapSize Core Setup ${version}.${ext}",
      "shortcutName": "CapSize",
      "uninstallDisplayName": "CapSize",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.5.0",
    "node-machine-id": "^1.1.12",
    "tesseract.js": "^5.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3"
  }
}